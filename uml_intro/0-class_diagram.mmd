classDiagram
    class Library {
        +add_book(book)
        +register_user(user)
        +create_loan(user, book)
    }

    class Book {
        +title: str
        +author: str
        +state: bool
        +mark_as_unavailable()
        +mark_as_available()
    }

    class User {
        +name: str
        +email: str
    }

    class Loan {
        +start_date: str
        +end_date: str
        +close_loan()
    }

    Library "1" o-- "0..*" Book : manages
    Library "1" o-- "0..*" User : manages
    Library "1" o-- "0..*" Loan : manages
    Loan "1" --> "1" Book : references
    Loan "1" --> "1" User : references
